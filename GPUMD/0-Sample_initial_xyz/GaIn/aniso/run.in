potential nep.txt
velocity 20
time_step 1

# === T = 20 K ===
# Relax at NPT
ensemble npt_mttk temp 20 20 aniso 1e-4 1e-4
dump_thermo 1000
run 10000

# Sampling with canonical MC
ensemble npt_mttk temp 20 20 aniso 1e-4 1e-4
mc canonical 1000 1000 300 20
dump_thermo 1000
dump_exyz 10000
run 20000

# Relax at NPT
ensemble npt_mttk temp 20 20 aniso 1e-4 1e-4
dump_thermo 1000
dump_exyz 10000
run 10000

